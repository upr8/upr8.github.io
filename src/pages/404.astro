---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/i18n';

const enI18n = t('en');
const faI18n = t('fa');
---

<BaseLayout title="Page Not Found | صفحه یافت نشد" description="The page you're looking for doesn't exist.">
  <div class="py-16 text-center">
    <h2 class="text-6xl font-bold text-primary mb-4">404</h2>

    <!-- English message -->
    <p class="text-xl text-secondary mb-2">
      {enI18n.notFound.message}
    </p>

    <!-- Persian message -->
    <p class="text-xl text-secondary mb-8" dir="rtl" lang="fa">
      {faI18n.notFound.message}
    </p>

    <div class="flex justify-center gap-4 flex-wrap">
      <a
        href="/en/"
        class="inline-block px-6 py-3 bg-accent-primary text-white rounded-lg hover:opacity-90 transition-opacity no-underline"
      >
        {enI18n.notFound.goHome}
      </a>
      <a
        href="/fa/"
        class="inline-block px-6 py-3 bg-accent-primary text-white rounded-lg hover:opacity-90 transition-opacity no-underline"
        dir="rtl"
        lang="fa"
      >
        {faI18n.notFound.goHome}
      </a>
    </div>
  </div>
</BaseLayout>
